# =============================================================================
# LinuxIO — pmlogger configuration
# Logs all base metrics required by the derived metrics in pcp-derived.conf
# Installed to /etc/pcp/pmlogger/config.d/linuxio.config
# =============================================================================

log mandatory on 15sec {
    # --- Uptime ---
    kernel.all.uptime

    # --- CPU ---
    hinv.ncpu
    kernel.all.cpu.idle
    kernel.all.cpu.user
    kernel.all.cpu.sys
    kernel.all.cpu.wait.total
    kernel.all.cpu.steal
    kernel.percpu.cpu.idle

    # --- Memory ---
    mem.physmem
    mem.util.available
    mem.util.bufmem
    mem.util.cached
    mem.util.swapTotal
    mem.util.swapFree

    # --- Network (per interface) ---
    network.interface.in.bytes
    network.interface.out.bytes
    network.interface.in.packets
    network.interface.out.packets

    # --- Disk I/O (per device) ---
    disk.dev.read_bytes
    disk.dev.write_bytes
    disk.dev.read
    disk.dev.write

    # --- Filesystem (per mount) ---
    filesys.capacity
    filesys.avail

    # --- Load average ---
    kernel.all.load
}

# --- PMDA metrics (logged only when the PMDA is active) ---

log advisory on 15sec {
    # lmsensors
    lmsensors

    # SMART
    smart.temperature_celsius
    smart.power_on_hours
    smart.health

    # Docker (per container)
    docker.memory.usage
    docker.memory.limit
    docker.cpu.usage.total
    docker.net.rx_bytes
    docker.net.tx_bytes
    docker.container.name

    # NFS client (per mount)
    nfsclient.bytes.read.normal
    nfsclient.bytes.write.normal
    nfsclient.ops.read
    nfsclient.ops.write

    # ZFS
    zfs.arc.size
    zfs.arc.hits
    zfs.arc.misses
    zfs.pool.allocated
    zfs.pool.size

    # libvirt VMs (per guest)
    libvirt.cpu.time
    libvirt.memory.current
    libvirt.memory.maximum
    libvirt.block.rd_bytes
    libvirt.block.wr_bytes
    libvirt.net.rx_bytes
    libvirt.net.tx_bytes
}
