{
  "name": "Linux Server i/O",
  "description": "Linux server managment tool",
  "author": "MordilloSan <miguelgalizamariz@gmail.com>",
  "private": true,
  "type": "module",
  "license": "GPL-2.0-only",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "vite",
    "lint": "TSESTREE_NO_INVALIDATION=true eslint src --ext .js,.jsx,.ts,.tsx --fix --cache --cache-location .eslintcache",
    "icons:generate": "node scripts/generate-icons.mjs",
    "build": "vite build",
    "analyze": "BUNDLE_ANALYZE=true vite build",
    "bundle:metrics": "node scripts/bundle-metrics.mjs",
    "bundle:budget": "node scripts/bundle-metrics.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "update": "npm update && npm outdated"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "not IE 11"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@iconify/react": "^6.0.2",
    "@novnc/novnc": "^1.7.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ace-builds": "^1.44.0",
    "framer-motion": "^12.40.0",
    "react": "^19.2.7",
    "react-ace": "^14.0.1",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "smoothie": "^1.36.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/eos-icons": "^1.2.4",
    "@iconify-json/la": "^1.2.1",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ph": "^1.2.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-bundle-analyzer": "^1.3.8",
    "vite-plugin-compression2": "^2.5.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "eslint-plugin-react": {
      "eslint": ">=9"
    }
  }
}
